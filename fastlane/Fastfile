require 'yaml'

config_path = File.join(ENV['CM_BUILD_DIR'] || Dir.pwd, 'project_config.yml')
CONFIG = YAML.load_file(config_path)

default_platform(:ios)

platform :ios do

  desc "Build IPA for App Store (including NotificationsTarget extension)"
  lane :build do
    gym(
      project: CONFIG['xcode_project'],
      scheme: CONFIG['xcode_scheme'],
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "./build/ios/ipa",
      output_name: CONFIG['output_name']
    )
  end

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    key_path = File.join(ENV["CM_BUILD_DIR"] || Dir.pwd, "fastlane", "keys", "AuthKey.p8")

    UI.message("Loading API key from: #{key_path}")

    unless File.exist?(key_path)
      UI.user_error!("API key file not found at #{key_path}. Please add your AuthKey.p8 to fastlane/keys/")
    end

    api_key = app_store_connect_api_key(
      key_id: CONFIG['asc_key_id'],
      issuer_id: CONFIG['asc_issuer_id'],
      key_filepath: key_path,
      in_house: false
    )

    UI.success("API key loaded successfully!")

    deliver(
      api_key: api_key,
      app_identifier: CONFIG['bundle_identifier'],
      app_version: CONFIG['app_version'],
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      skip_binary_upload: false,
      skip_app_version_update: false,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

end
